# =============================================================================
# Repo-root .env — read ONLY by docker-compose.yml at build/up time.
#
# Scope:
#   • Domains for Caddy (APP_DOMAIN, BOT_DOMAIN)
#   • Next.js public build args baked into the web image (NEXT_PUBLIC_*)
#
# All other secrets live in:
#   • web/.env     — runtime env for the web container (auth, DB, …)
#   • server/.env  — runtime env for the bot container (TTS, STT, LLM, R2, …)
#
# Copy this file to .env at repo root and fill in the values below.
# =============================================================================

APP_DOMAIN=luna.example.com
BOT_DOMAIN=bot.luna.example.com

NEXT_PUBLIC_APP_URL=https://luna.example.com
BOT_PUBLIC_URL=https://bot.luna.example.com

# Public build-time values for the Next.js browser bundle.
NEXT_PUBLIC_BRAND_NAME=luna
NEXT_PUBLIC_BOT_NAME=luna
