# =============================================================================
# web/.env — read by the Next.js app (web/)
#
# Copy this file to web/.env (or web/.env.local) and fill in secrets.
# On Vercel, add the same keys via the project's Environment Variables UI.
#
# Bot-only keys live in server/.env.example:
#   • TTS_*, VAD_*, STT_*, LLM_*, RHYTHM_PAUSE_*
#   • CARTESIA_*, ELEVENLABS_*
#   • CONVERSATION_LLM_*, OPENER_MODE
# Do NOT put those here — the web app does not read them.
# =============================================================================

# -----------------------------------------------------------------------------
# Shared (the same values must also appear in server/.env)
# -----------------------------------------------------------------------------
DATABASE_URL="postgres://user:pass@ep-xyz.neon.tech/luna?sslmode=require"
BOT_SHARED_SECRET=""           # MUST match server/.env BOT_SHARED_SECRET
                               # Generate with: openssl rand -base64 48
OPENAI_API_KEY=""              # used for embeddings (memory) + splash copy
SARVAM_API_KEY=""              # reflector chat (sarvamChat)
SARVAM_CHAT_MODEL="sarvam-30b" # optional: sarvam-30b (default) or sarvam-105b
BRAND_NAME="luna"
BOT_NAME=""                    # falls back to BRAND_NAME
BOT_GENDER="feminine"          # feminine | masculine | neutral

# -----------------------------------------------------------------------------
# Next.js runtime
# -----------------------------------------------------------------------------
NODE_ENV="development"
# VERCEL_URL is auto-injected on Vercel; leave unset locally

# -----------------------------------------------------------------------------
# Public bundle (baked into the browser JS at next build time)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_BOT_URL="http://localhost:7860"     # local dev; prod = bot domain
NEXT_PUBLIC_BRAND_NAME="luna"
NEXT_PUBLIC_BOT_NAME="luna"

# -----------------------------------------------------------------------------
# Bot endpoints (server-side only, NOT baked into the browser bundle)
# -----------------------------------------------------------------------------
BOT_INTERNAL_URL="http://localhost:7860"        # SSR -> bot, private path
BOT_PUBLIC_URL="http://localhost:7860"          # browser -> bot, public path

# -----------------------------------------------------------------------------
# Auth + session secrets (server-side only)
# -----------------------------------------------------------------------------
GUEST_COOKIE_SECRET=""         # HMAC for the anonymous-guest cookie
                               # Generate with: openssl rand -base64 48

# -----------------------------------------------------------------------------
# Usage limits (operator-configured — no billing, this is cost protection)
# -----------------------------------------------------------------------------
MAX_CALL_SECONDS="600"         # hard per-session call budget, signed into the
                               # bot's session token (the `bud` claim)
DAILY_LIMIT_MINUTES="15"       # per-user, per-IST-day usage cap, computed from
                               # the sessions table. Applies to anonymous AND
                               # authed users alike. Set to "0" to disable.

# -----------------------------------------------------------------------------
# Resend transactional email — https://resend.com (password reset, etc.)
# Verify your sending domain in Resend, then set EMAIL_FROM to a verified
# address. The API key needs "Sending access" only.
# -----------------------------------------------------------------------------
RESEND_API_KEY=""              # re_...
EMAIL_FROM=""                  # e.g. hello@luna.example.com

# -----------------------------------------------------------------------------
# Cloudflare R2 — keys must match server/.env. The bot uploads recordings,
# the web app generates presigned playback URLs from the same bucket.
# -----------------------------------------------------------------------------
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET="luna-recordings"
R2_PUBLIC_BASE_URL=""          # optional: https://recordings.your-domain.com

# -----------------------------------------------------------------------------
# Landing-page splash copy (optional)
# -----------------------------------------------------------------------------
COPY_PROVIDER=""               # "openai" | "sarvam" | "" (auto)
COPY_MODEL="gpt-4.1-nano"
TAGLINE="someone's here to listen"
