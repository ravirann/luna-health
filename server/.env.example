# =============================================================================
# server/.env — read by the Pipecat voice bot (server/bot.py)
#
# Copy this file to server/.env and fill in the secrets.
#
# Web-only keys live in web/.env.example:
#   • NEXT_PUBLIC_*, GUEST_COOKIE_SECRET, NODE_ENV
#   • DAILY_LIMIT_MINUTES, BOT_INTERNAL_URL, BOT_PUBLIC_URL
#   • COPY_PROVIDER, COPY_MODEL, TAGLINE
# Do NOT put those here — the bot does not read them and it pollutes the file.
# =============================================================================

# -----------------------------------------------------------------------------
# Shared (the same values must also appear in web/.env)
# -----------------------------------------------------------------------------
DATABASE_URL=""                # bot writes transcripts/sessions; web reads
BOT_SHARED_SECRET=""           # bot signs JWT, web verifies — keep identical
OPENAI_API_KEY=""              # bot LLM (when CONVERSATION_LLM_PROVIDER=openai); web embeddings
SARVAM_API_KEY=""              # bot STT; web sarvamChat (reflector)
BRAND_NAME="luna"
BOT_NAME=""                    # voice persona name; falls back to BRAND_NAME
BOT_GENDER="feminine"          # feminine | masculine | neutral

# -----------------------------------------------------------------------------
# Bot identity / lifecycle
# -----------------------------------------------------------------------------
ENV="dev"                       # dev | prod — gates anonymous-session paths
ALLOW_UNAUTHENTICATED_BOT=false # let the bot accept offers without a session token
REQUIRE_BOT_SESSION=true        # require a signed session token on /api/offer
NEXT_APP_URL="http://localhost:3000"  # bot calls back to /api/session/:id/end here
# Fallback call budget only — the real per-call budget is the signed `bud`
# claim inside assistantToken (HMAC-verified, same as sub/sid/exp). This env
# is used only when there's no session token at all (anonymous/dev mode) or
# the token predates the `bud` claim. The request body's callBudgetSecs is
# unsigned/browser-relayed and is never trusted, regardless of this env.
MAX_CALL_SECONDS=600
CALL_WARN_SECONDS=150           # soft-warn 30s before budget ends
OPENER_MODE=llm                 # llm | template

# -----------------------------------------------------------------------------
# Conversation LLM ("brain" between STT and TTS)
#   sarvam   Indic-focused, uses SARVAM_API_KEY
#   openai   stronger conversation quality, uses OPENAI_API_KEY + model below
# -----------------------------------------------------------------------------
CONVERSATION_LLM_PROVIDER=openai
CONVERSATION_LLM_MODEL=gpt-4.1-mini

# OpenAI-only tuning. Higher temperature + non-zero penalties keep replies
# varied across turns. max_tokens keeps replies speakable.
LLM_TEMPERATURE=0.85
LLM_PRESENCE_PENALTY=0.6
LLM_FREQUENCY_PENALTY=0.5
LLM_MAX_TOKENS=120

# -----------------------------------------------------------------------------
# Safety / crisis handling
#   Tier-1 lexical screen runs locally, no config needed. Tier-2 (one yes/no
#   classification call on a tier-1 hit) reuses the CONVERSATION_LLM_PROVIDER
#   credentials above — no separate key, no new SDK.
# -----------------------------------------------------------------------------
RISK_GRACE_SECONDS=300           # one-shot call-budget extension on confirmed crisis
# CRISIS_RESOURCES overrides the built-in defaults (Tele-MANAS / Vandrevala
# Foundation / AASRA / findahelpline.com — all 24/7, verified 2026-07-12;
# re-verify before each release). Format: `;`-separated entries of
# `name|contact|note`, note optional, e.g.:
# CRISIS_RESOURCES="Tele-MANAS|14416|also 1-800-891-4416, 24/7;Vandrevala Foundation|9999 666 555|call or WhatsApp, 24/7;AASRA|022-27546669|24/7;Find A Helpline|findahelpline.com|outside India"

# -----------------------------------------------------------------------------
# Speech-to-text (Sarvam saaras). Indic auto-detect + good Hinglish.
# -----------------------------------------------------------------------------
STT_MODEL=saaras:v3
STT_HIGH_VAD_SENSITIVITY=true

# -----------------------------------------------------------------------------
# Voice activity detection + turn taking
# -----------------------------------------------------------------------------
VAD_CONFIDENCE=0.70
VAD_START_SECS=0.20
VAD_STOP_SECS=0.40
VAD_MIN_VOLUME=0.55
USER_SPEECH_TIMEOUT=0.55
USER_TURN_STOP_TIMEOUT=8.0
AUDIO_IDLE_TIMEOUT=2.0

# -----------------------------------------------------------------------------
# TTS provider selection. The factory in luna_bot/voice/tts.py reads the
# right block of vars for the active provider.
#   sarvam     Indian voices, Hinglish-friendly (uses SARVAM_API_KEY above)
#   cartesia   broader voice library, more emotive Sonic voices
#   elevenlabs natural multilingual voices; library voices need a paid plan
# -----------------------------------------------------------------------------
TTS_PROVIDER=elevenlabs

# Sarvam TTS knobs (only used when TTS_PROVIDER=sarvam).
TTS_MODEL=bulbul:v3-beta
TTS_VOICE=priya
TTS_PACE=0.96
TTS_TEMPERATURE=0.68

# Cartesia (only used when TTS_PROVIDER=cartesia).
CARTESIA_API_KEY=""
CARTESIA_VOICE_ID=""
CARTESIA_MODEL=sonic-3
CARTESIA_LANGUAGE=hi
CARTESIA_SPEED=0.94
CARTESIA_EMOTION=sympathetic
CARTESIA_VOLUME=1.0

# ElevenLabs (only used when TTS_PROVIDER=elevenlabs).
# Library voices (e.g. Anvi) require a paid ElevenLabs plan.
ELEVENLABS_API_KEY=""
ELEVENLABS_VOICE_ID=""
ELEVENLABS_MODEL=eleven_flash_v2_5
ELEVENLABS_LANGUAGE=hi
ELEVENLABS_STABILITY=0.35
ELEVENLABS_SIMILARITY_BOOST=0.85
ELEVENLABS_STYLE=0.45
ELEVENLABS_USE_SPEAKER_BOOST=true
ELEVENLABS_SPEED=0.85

# -----------------------------------------------------------------------------
# Inter-sentence pauses (HumanRhythmProcessor — real asyncio sleeps between
# TTS chunks, so they hold even when the TTS engine ignores punctuation).
# -----------------------------------------------------------------------------
RHYTHM_PAUSE_DEFAULT=0.55
RHYTHM_PAUSE_QUESTION=0.45
RHYTHM_PAUSE_ACK=0.70
RHYTHM_PAUSE_ELLIPSIS=0.85

# -----------------------------------------------------------------------------
# Cloudflare R2 — bot uploads session audio; web reads via presigned URLs.
# -----------------------------------------------------------------------------
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET="luna-recordings"
